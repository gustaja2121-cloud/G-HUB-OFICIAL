rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /system/health {
      allow read: if true;
    }

    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    // REMOVED: isVerified() for faster strategic access as requested
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['streak', 'lastActiveDate', 'totalVideosCreated', 'totalVideosPosted', 'xp', 'level', 'lastResetDate', 'userId']) &&
             data.streak is number && data.xp is number && data.level is number &&
             data.userId == request.auth.uid;
    }

    function isValidNote(data) {
      return data.keys().hasAll(['title', 'createdAt', 'userId']) &&
             data.title is string && data.userId == request.auth.uid;
    }

    function isValidChecklistTask(data) {
      return data.keys().hasAll(['title', 'completed', 'type', 'userId']) &&
             data.title is string && data.completed is bool &&
             data.userId == request.auth.uid;
    }

    function isValidFinance(data) {
      return data.keys().hasAll(['amount', 'description', 'date', 'userId']) &&
             data.amount is number && data.userId == request.auth.uid;
    }

    function isValidVideoPerformance(data) {
      return data.keys().hasAll(['data', 'quantidade', 'userId']) &&
             data.userId == request.auth.uid;
    }

    function isValidAccount(data) {
      return data.keys().hasAll(['platform', 'login', 'userId']) &&
             data.userId == request.auth.uid;
    }

    function isValidRanking(data) {
      return data.keys().hasAll(['myRank', 'myViews', 'leaderRank', 'leaderViews', 'userId']) &&
             data.userId == request.auth.uid;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());
    }

    match /notes/{noteId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(noteId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(noteId) && isValidNote(incoming());
      allow update: if isSignedIn() && isValidId(noteId) && resource.data.userId == request.auth.uid && isValidNote(incoming());
      allow delete: if isSignedIn() && isValidId(noteId) && resource.data.userId == request.auth.uid;
    }

    match /dailyChecklist/{checklistId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(checklistId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(checklistId) && isValidChecklistTask(incoming());
      allow update: if isSignedIn() && isValidId(checklistId) && resource.data.userId == request.auth.uid && isValidChecklistTask(incoming());
      allow delete: if isSignedIn() && isValidId(checklistId) && resource.data.userId == request.auth.uid;
    }

    match /finance/{financeId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(financeId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(financeId) && isValidFinance(incoming());
      allow update: if isSignedIn() && isValidId(financeId) && resource.data.userId == request.auth.uid && isValidFinance(incoming());
      allow delete: if isSignedIn() && isValidId(financeId) && resource.data.userId == request.auth.uid;
    }

    match /videoPerformance/{perfId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(perfId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(perfId) && isValidVideoPerformance(incoming());
      allow update: if isSignedIn() && isValidId(perfId) && resource.data.userId == request.auth.uid && isValidVideoPerformance(incoming());
      allow delete: if isSignedIn() && isValidId(perfId) && resource.data.userId == request.auth.uid;
    }

    match /rankings/{rankId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(rankId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(rankId) && isValidRanking(incoming());
      allow update: if isSignedIn() && isValidId(rankId) && resource.data.userId == request.auth.uid && isValidRanking(incoming());
      allow delete: if isSignedIn() && isValidId(rankId) && resource.data.userId == request.auth.uid;
    }

    match /accounts/{accountId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(accountId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(accountId) && isValidAccount(incoming());
      allow update: if isSignedIn() && isValidId(accountId) && resource.data.userId == request.auth.uid && isValidAccount(incoming());
      allow delete: if isSignedIn() && isValidId(accountId) && resource.data.userId == request.auth.uid;
    }
  }
}
